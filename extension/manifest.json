{
  "manifest_version": 3,
  "name": "VoiceGuard AI",
  "version": "1.0",
  "description": "Real-time voice deepfake detection",
  "permissions": ["activeTab", "scripting", "storage", "tabCapture", "offscreen"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VoiceGuard AI"
  }
}